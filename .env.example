# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=jctire
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=jctiredb
DATABASE_URL=postgresql://jctire:changeme_strong_password@postgres:5432/jctiredb

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=changeme_32char_random_string_here
NEXTAUTH_URL=https://jctireshop.com

# ─── Admin Credentials ───────────────────────────────────────────────────────
# Your login email
ADMIN_EMAIL=owner@jctireshop.com
# Generate hash: node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$examplehashhere

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use a Gmail App Password (not your regular password)
# Enable at: myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourstore@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_TO=owner@jctireshop.com

# ─── Google Places API (for testimonials) ────────────────────────────────────
# Get API key: console.cloud.google.com → Enable "Places API"
GOOGLE_PLACES_API_KEY=your_google_places_api_key
# Find Place ID: developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=ChIJyour_place_id_here

# ─── Calendly ─────────────────────────────────────────────────────────────────
# Your Calendly booking page URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/appointment
